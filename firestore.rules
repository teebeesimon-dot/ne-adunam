rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helpers
    // -------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userExists() {
      return isAuthenticated() && userDoc().exists;
    }

    function userRole() {
      return userExists() ? userDoc().data.role : null;
    }

    function isSuperAdmin() {
      return userExists() && userRole() == 'super_admin';
    }

    function isOrganizer() {
      return userExists() && userRole() == 'organizer';
    }

    function canCreateEvents() {
      return isSuperAdmin() || isOrganizer();
    }

    function canReadUserProfiles() {
      return isSuperAdmin() || isOrganizer();
    }

    function isSuperAdminEmail() {
      return isAuthenticated()
        && request.auth.token.email == 'teebeesimon@gmail.com';
    }

    function initialRoleForNewUser() {
      return isSuperAdminEmail() ? 'super_admin' : 'user';
    }

    function validAttendanceStatus(status) {
      return status in ['vin', 'poate', 'nu_vin'];
    }

    function roleUnchanged() {
      return request.resource.data.role == resource.data.role;
    }

    // -------------------------------------------------------------------------
    // users/{userId}
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Read own profile, or organizer / super_admin may read user profiles
      allow get: if isAuthenticated() && (
        request.auth.uid == userId || canReadUserProfiles()
      );

      // Admin panel: super_admin lists all users
      allow list: if isSuperAdmin();

      // First login: create own profile with server-validated initial role
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == initialRoleForNewUser()
        && request.resource.data.keys().hasAll([
          'uid', 'displayName', 'email', 'role', 'createdAt'
        ]);

      // Self: update profile fields only (role must not change)
      // Exception: configured super-admin email may bootstrap super_admin role
      // Super admin: may update role on other users (user <-> organizer only)
      allow update: if isAuthenticated() && (
        (
          request.auth.uid == userId
          && (
            roleUnchanged()
            || (isSuperAdminEmail() && request.resource.data.role == 'super_admin')
          )
        )
        || (
          isSuperAdmin()
          && request.auth.uid != userId
          && request.resource.data.role in ['user', 'organizer']
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['role', 'updatedAt'])
        )
      );

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // events/{eventId}
    // Authenticated users with the event ID (direct link) can read one event.
    // Listing is restricted to events owned by the caller (home page).
    // -------------------------------------------------------------------------

    match /events/{eventId} {
      allow get: if isAuthenticated();

      allow list: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      allow create: if canCreateEvents()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'title', 'sport', 'date', 'time', 'maxParticipants', 'ownerId', 'createdAt'
        ]);

      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || isSuperAdmin()
      );

      allow delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || isSuperAdmin()
      );
    }

    // -------------------------------------------------------------------------
    // responses/{responseId}  — document id: {eventId}_{userId}
    // -------------------------------------------------------------------------

    match /responses/{responseId} {
      function isResponseOwner() {
        return isAuthenticated() && resource.data.userId == request.auth.uid;
      }

      function isCreatingOwnResponse() {
        return isAuthenticated()
          && request.resource.data.userId == request.auth.uid
          && responseId == request.resource.data.eventId + '_' + request.auth.uid
          && validAttendanceStatus(request.resource.data.status);
      }

      // Authenticated users may read responses (e.g. event attendance lists)
      allow get, list: if isAuthenticated();

      allow create: if isCreatingOwnResponse()
        && request.resource.data.keys().hasAll([
          'eventId', 'userId', 'status', 'createdAt'
        ]);

      allow update: if isResponseOwner()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.eventId == resource.data.eventId
        && validAttendanceStatus(request.resource.data.status);

      allow delete: if isResponseOwner();
    }

    // -------------------------------------------------------------------------
    // Deny everything else
    // -------------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
